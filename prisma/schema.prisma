generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  orders        Order[]
  settings      Setting[]
  shippingRules ShippingRule[]
  creditCards   CreditCard[]
  senderRules   SenderRule[]
  createdAt     DateTime       @default(now())
}

model SenderRule {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  pattern   String   // substring match against sender email address
  createdAt DateTime @default(now())
}

model CreditCard {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  rewardsRate Float    @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
}

model Buyer {
  id            Int            @id @default(autoincrement())
  name          String
  orders        Order[]
  shippingRules ShippingRule[]
  createdAt     DateTime       @default(now())
}

model BlockedAddress {
  id        Int      @id @default(autoincrement())
  label     String
  pattern   String
  createdAt DateTime @default(now())
}

model ShippingRule {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  label     String
  pattern   String
  buyerId   Int?
  buyer     Buyer?   @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  platform        String
  orderNumber     String?
  orderDate       DateTime
  itemDescription String?
  cost            Float
  shippingCost    Float       @default(0)
  salePrice       Float?
  buyerId         Int?
  buyer           Buyer?      @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  cardId          Int?
  card            CreditCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  cashbackAmount  Float       @default(0)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
