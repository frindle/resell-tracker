generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  orders        Order[]
  settings      Setting[]
  shippingRules ShippingRule[]
  creditCards   CreditCard[]
  senderRules   SenderRule[]
  bfmrWatchers  BfmrWatcher[]
  bgCommitments    BuyingGroupCommitment[]
  bfmrReservations BfmrReservation[]
  createdAt        DateTime       @default(now())
}

model SenderRule {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  pattern   String   // substring match against sender email address
  createdAt DateTime @default(now())
}

model CreditCard {
  id            Int                @id @default(autoincrement())
  userId        Int?
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  name                String
  last4               String?  // last 4 digits — used for auto-assigning a card on order import when the scraped payment method matches
  milesProgram        String?  // e.g. "Chase UR", "Amex MR", "Delta SkyMiles"
  rewardsRate         Float?
  basePointsPerDollar Float?
  spendYearType       String  @default("calendar")  // "calendar" | "cardmember"
  spendYearResetMMDD  String?  // e.g. "03/15" — only used when spendYearType = "cardmember"
  merchantRates       CardMerchantRate[]
  orders        Order[]
  createdAt     DateTime           @default(now())
}

model CardMerchantRate {
  id              Int        @id @default(autoincrement())
  cardId          Int
  card            CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  merchant        String
  pointsPerDollar Float
  createdAt       DateTime   @default(now())

  @@unique([cardId, merchant])
}

model Buyer {
  id            Int            @id @default(autoincrement())
  name          String
  orders        Order[]
  shippingRules ShippingRule[]
  createdAt     DateTime       @default(now())
}

model BlockedAddress {
  id        Int      @id @default(autoincrement())
  label     String
  pattern   String
  createdAt DateTime @default(now())
}

model ShippingRule {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  label     String
  pattern   String
  buyerId   Int?
  buyer     Buyer?   @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model BgDealSnapshot {
  id          Int      @id @default(autoincrement())
  dealId      String
  title       String
  storeName   String
  retailPrice Float
  payoutPrice Float
  snapshotAt  DateTime @default(now())

  @@index([dealId])
}

model BgResolvedOrder {
  id        Int      @id @default(autoincrement())
  orderId   String   @unique  // BG order_id e.g. "O-2521881381"
  createdAt DateTime @default(now())
}

model PortalRate {
  id         Int      @id @default(autoincrement())
  merchant   String   // e.g. "Walmart", "Best Buy" — matched against vendor_name from BFMR
  category   String   @default("")  // e.g. "Electronics" — empty string = applies to all
  portal     String   // e.g. "TopCashback", "Rakuten"
  rate       String   // e.g. "3%", "4.5%", "Excluded", "$5 flat"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([merchant, portal, category])
  @@index([merchant])
}

model BfmrWatcher {
  id          Int       @id @default(autoincrement())
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealSlug    String
  dealTitle   String?
  itemId      Int
  itemName    String?
  qty         Int
  active      Boolean   @default(true)
  lastChecked DateTime?
  lastResult  String?
  reservedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model ExtensionCommand {
  id        Int      @id @default(autoincrement())
  type      String   // SYNC_AMAZON | SYNC_WALMART | SYNC_COSTCO | SYNC_BIGSKY | SCRAPE_CBM
  payload   String?  // JSON
  status    String   @default("pending") // pending | running | done | failed
  result    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BfmrSkip {
  id          Int      @id @default(autoincrement())
  orderNumber String   @unique
  createdAt   DateTime @default(now())
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  platform        String
  orderNumber     String?
  orderDate       DateTime
  itemDescription String?
  cost            Float
  shippingCost    Float       @default(0)
  insuranceCost   Float       @default(0)
  salePrice         Float?
  salePriceSynced   Boolean     @default(false)
  buyerId         Int?
  buyer           Buyer?      @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  cardId          Int?
  card            CreditCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  cashbackAmount  Float       @default(0)
  sourceUrl       String?
  shippingAddress String?
  trackingNumbers          String?   // comma-separated
  trackingValues           String?   // JSON: { [trackingNumber]: value }
  trackingSubmittedToBg    Boolean   @default(false)
  bgExpectedPayout         Float?
  bgPaidAmount             Float?
  notes            String?
  skipAddressBlock Boolean     @default(false)
  ignoredByRule    Boolean     @default(false)
  blockedAddressPattern String? // set on import when the address matched a BlockedAddress pattern; clears when user approves the order
  bgCredited       Boolean   @default(false)  // BG has a receipt in balance for this order
  buyerMismatch    Boolean   @default(false)  // paying group doesn't match assigned buyer
  groupReferenceId String?   // group-specific reference: BFMR order_id override, CardCenter payment ID, etc.
  bfmrReceived     Boolean     @default(false)
  bfmrStatus       String?   // last known BFMR status: received, processed, paid, etc.
  bfmrRejectedItems String?  // JSON array of {name, reason} for rejected items at processing
  returnStatus     String?   // null | 'initiated' | 'shipped' | 'dropped_off' | 'refunded' | 'written_off'
  returnTracking   String?   // return shipment tracking number (label-based returns)
  overdueAt        DateTime?
  lost             Boolean     @default(false)
  locked           Boolean     @default(false)
  attachments      OrderAttachment[]
  giftCards        GiftCard[]
  costcoReceipts   CostcoReceipt[]
  commitmentLinks  OrderCommitmentLink[]
  bfmrLinks        OrderBfmrLink[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// One row per active commitment fetched from BuyingGroup's
// /v1/commitment/get_commitments. Snapshot of what BG thinks we owe them.
// Synced via /api/buyinggroup/sync-commitments — upsert by commitmentId.
model BuyingGroupCommitment {
  id              Int      @id @default(autoincrement())
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  commitmentId    String   // BG's "CM-..." identifier
  dealId          String   // BG's "DL-..." identifier
  dealTitle       String
  itemId          String?
  itemImage       String?
  count           Int      // total committed quantity
  fulfilled       Int      // quantity BG has recorded as delivered
  expiryDay       DateTime?
  price           Float    // per-unit price
  commission      Float    @default(0)
  total           Float    // price × count
  bgPointsReward  Float    @default(0)
  status          String   // "ACTIVE", etc.
  raw             String?  // JSON of the full BG record for future fields
  createdDt       DateTime?
  lastSyncedAt    DateTime @default(now())

  orderLinks      OrderCommitmentLink[]

  @@unique([userId, commitmentId])
  @@index([dealId])
  @@index([userId, status])
}

// Many-to-many between Order and BuyingGroupCommitment. Lets the user
// assign N orders (or N units of an order) to a single commitment to
// satisfy the committed count. `quantity` is how many units of this order
// count toward the commitment.
model OrderCommitmentLink {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  commitmentId Int
  commitment   BuyingGroupCommitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())

  @@unique([orderId, commitmentId])
  @@index([commitmentId])
}

// Snapshot of a BFMR tracker row. One row per reservation/shipment from
// BFMR's /my-tracker API. Synced via /api/bfmr/sync-reservations.
model BfmrReservation {
  id              Int       @id @default(autoincrement())
  userId          Int?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  reserveId       String?
  purchaseId      String?
  shipmentId      String?
  bfmrOrderId     String?   // BFMR's order_id (retailer order number)
  trackingNumber  String?
  dealTitle       String?
  itemName        String?
  status          String
  qty             Int       @default(1)
  retailPrice     Float?
  totalPayout     Float?
  datePaid        DateTime?
  raw             String?
  lastSyncedAt    DateTime  @default(now())

  orderLinks      OrderBfmrLink[]

  @@unique([userId, reserveId])
  @@index([userId, status])
  @@index([bfmrOrderId])
}

// Links an Order to a BfmrReservation, optionally scoped to a specific
// tracking number on the order. quantity = how many items from this
// reservation ship under this tracking. value = payout for those items.
model OrderBfmrLink {
  id              Int      @id @default(autoincrement())
  orderId         Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reservationId   Int
  reservation     BfmrReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  trackingNumber  String?
  quantity        Int      @default(1)
  value           Float?
  createdAt       DateTime @default(now())

  @@unique([orderId, reservationId, trackingNumber])
  @@index([reservationId])
}

model OrderAttachment {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filename     String   // stored filename on disk
  originalName String   // original upload name
  mimeType     String
  createdAt    DateTime @default(now())
}

model CostcoReceipt {
  id                 Int      @id @default(autoincrement())
  transactionBarcode String   @unique
  transactionDate    String   // YYYY-MM-DD
  warehouseName      String
  total              Float
  receiptData        String   // full JSON from Costco API
  orderId            Int?
  order              Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
}

model GiftCard {
  id             Int       @id @default(autoincrement())
  orderId        Int
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchant       String
  value          Float
  cardNumber     String
  pin            String?
  ccSubmittedAt   DateTime?
  ccGiftCardId    String?   // CC's gift card ID (e.g. 8232432) — card identity, stable across multiple sales/listings
  ccListingId     String?   // CC's listing ID (e.g. 9045043) — specific sale event; the payment is tied to a listing, not the card
  ccReservationId Int?
  ccSubmissionId  String?
  ccPurchasePrice Float?    // what CardCenter actually paid for this card (set at submission time)
  createdAt       DateTime  @default(now())
}

// One row per scrape/import call. Surfaces "what did the last sync touch?"
// on the sync-history page and behind clickable banner cards.
model SyncEvent {
  id          Int               @id @default(autoincrement())
  userId      Int?
  platform    String            // 'Amazon' | 'Walmart' | 'Costco' | etc.
  scraped     Int               @default(0)
  imported    Int               @default(0)
  updated     Int               @default(0)
  skipped     Int               @default(0)
  createdAt   DateTime          @default(now())
  orderChanges SyncEventOrder[]

  @@index([userId, createdAt])
}

// Per-order detail for a SyncEvent. `changedFields` holds a JSON object of
// { fieldName: [oldValue, newValue] } pairs for updates, or the initial
// values for creates (oldValue=null).
model SyncEventOrder {
  id            Int       @id @default(autoincrement())
  eventId       Int
  event         SyncEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderId       Int?      // null if order was later deleted
  orderNumber   String?   // snapshot for resilience if order is gone
  action        String    // 'created' | 'updated'
  changedFields String    // JSON: { field: [old, new] }

  @@index([eventId])
}
